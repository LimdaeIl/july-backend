### 관리자 회원가입
# @name signUp
POST http://localhost:8080/api/v1/auth/sign-up
Content-Type: application/json

{
  "email": "july{{$timestamp}}@example.com",
  "password": "Password123!",
  "name": "관리자회원",
  "phone": "01012345678",
  "address": {
    "city": "서울특별시",
    "state": "강남구",
    "zip": "06236",
    "country": "대한민국"
  }
}

> {%
  client.global.set("adminEmail", response.body.data.email);
%}


### 관리자 로그인
# @name signIn
POST http://localhost:8080/api/v1/auth/sign-in
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "Password123!"
}

> {%
  client.global.set("adminAccessToken", response.body.data.accessToken);
%}


### 수정 테스트용 상품 생성
# @name createProduct
POST http://localhost:8080/api/v1/admin/products
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "수정 전 기계식 키보드",
  "price": 129000,
  "initialQuantity": 100
}

> {%
  client.global.set("productId", response.body.data.productId);
%}


### 상품 정보 수정

### 상품 정보 수정 성공
# @name updateProduct
PATCH http://localhost:8080/api/v1/admin/products/{{productId}}
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "수정 후 무선 기계식 키보드",
  "price": 159000
}


### 상품 정보 수정 실패 - 인증 토큰 없음
# @name updateProductWithoutToken
PATCH http://localhost:8080/api/v1/admin/products/{{productId}}
Content-Type: application/json

{
  "name": "인증되지 않은 상품 수정",
  "price": 169000
}


### 상품 정보 수정 실패 - 존재하지 않는 상품
# @name updateProductNotFound
PATCH http://localhost:8080/api/v1/admin/products/999999999
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "존재하지 않는 상품",
  "price": 169000
}


### 상품 정보 수정 실패 - 상품 ID 0
# @name updateProductInvalidProductId
PATCH http://localhost:8080/api/v1/admin/products/0
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "잘못된 상품 ID",
  "price": 169000
}


### 상품 정보 수정 실패 - 상품 ID 음수
# @name updateProductNegativeProductId
PATCH http://localhost:8080/api/v1/admin/products/-1
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "잘못된 상품 ID",
  "price": 169000
}


