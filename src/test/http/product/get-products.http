### 관리자 회원가입
# @name signUp
POST http://localhost:8080/api/v1/auth/sign-up
Content-Type: application/json

{
  "email": "july{{$timestamp}}@example.com",
  "password": "Password123!",
  "name": "관리자회원",
  "phone": "01012345678",
  "address": {
    "city": "서울특별시",
    "state": "강남구",
    "zip": "06236",
    "country": "대한민국"
  }
}

> {%
  client.global.set("adminEmail", response.body.data.email);
%}

### 관리자 로그인
# @name signIn
POST http://localhost:8080/api/v1/auth/sign-in
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "Password123!"
}

> {%
  client.global.set("adminAccessToken", response.body.data.accessToken);
  client.global.set("sellerId", response.body.data.id);
%}

### 상품 생성 1
POST http://localhost:8080/api/v1/admin/products
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "한정판 기계식 키보드",
  "price": 129000
}

### 상품 생성 2
POST http://localhost:8080/api/v1/admin/products
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "무선 게이밍 마우스",
  "price": 59000
}

### 상품 생성 3
POST http://localhost:8080/api/v1/admin/products
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "name": "울트라와이드 모니터",
  "price": 249000
}

### 상품 목록 조회 - 최신순
GET http://localhost:8080/api/v1/products?sortType=LATEST&page=0&size=20

### 상품 목록 조회 - 가격 낮은 순
GET http://localhost:8080/api/v1/products?sortType=PRICE_LOW&page=0&size=20

### 상품 목록 조회 - 가격 높은 순
GET http://localhost:8080/api/v1/products?sortType=PRICE_HIGH&page=0&size=20

### 판매자 상품 조회 - 최신순
GET http://localhost:8080/api/v1/products?sellerId={{sellerId}}&sortType=LATEST&page=0&size=20

### 판매자 상품 조회 - 가격 낮은 순
GET http://localhost:8080/api/v1/products?sellerId={{sellerId}}&sortType=PRICE_LOW&page=0&size=20

### 판매자 상품 조회 - 가격 높은 순
GET http://localhost:8080/api/v1/products?sellerId={{sellerId}}&sortType=PRICE_HIGH&page=0&size=20

### 잘못된 정렬 타입
GET http://localhost:8080/api/v1/products?sortType=INVALID&page=0&size=20

### 잘못된 페이지
GET http://localhost:8080/api/v1/products?page=-1&size=20

### 잘못된 페이지 크기
GET http://localhost:8080/api/v1/products?page=0&size=101

