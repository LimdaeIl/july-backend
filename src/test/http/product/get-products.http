%}

### 4-10. 커서 페이징 - 판매자 기준 가격 낮은 순 다음 페이지
# @name getProductsCursorBySellerPriceLowNext
GET http://localhost:8080/api/v1/products/cursor?sellerId={{sellerId}}&sortType=PRICE_LOW&cursorId={{sellerPriceLowCursorId}}&cursorPrice={{sellerPriceLowCursorPrice}}&size=2

### 4-11. 커서 페이징 - 판매자 기준 가격 높은 순 첫 페이지
# @name getProductsCursorBySellerPriceHighFirst
GET http://localhost:8080/api/v1/products/cursor?sellerId={{sellerId}}&sortType=PRICE_HIGH&size=2

> {%
  client.global.set(
      "sellerPriceHighCursorId",
      response.body.data.nextCursor.productId
  );
  client.global.set(
      "sellerPriceHighCursorPrice",
