@baseUrl = http://localhost:8080
@contentType = application/json
@password = Password123!

### =========================================================
### 주문 목록 조회 커서 페이징 시나리오
###
### 실행 순서:
### 1. 관리자 가입/로그인
### 2. 테스트 상품 생성
### 3. 구매자 가입/로그인
### 4. 주문 4건 생성
### 5. 주문 1건 취소
### 6. 기본/상태/키워드/커서 목록 조회
###
### 주의:
### - 관리자 가입 계정에 ADMIN 권한이 부여되는 환경을 전제로 한다.
### - GET /api/v1/orders 응답은 ApiResponse로 감싸지 않은
###   CursorResponse<OrderSummaryResponse, Long> 직접 응답을 전제로 한다.
### =========================================================


### 1-1. 관리자 회원가입
# @name signUpAdmin
POST {{baseUrl}}/api/v1/auth/sign-up
Content-Type: {{contentType}}

{
  "email": "order-admin-{{$timestamp}}@example.com",
  "password": "{{password}}",
  "name": "주문관리자",
  "phone": "01011112222",
  "address": {
    "city": "서울특별시",
    "state": "강남구",
    "zip": "06236",
    "country": "대한민국"
  }
}

> {%
client.test("관리자 회원가입 성공", function () {
  client.assert(
      response.status === 200 || response.status === 201,
      "예상 상태 코드: 200 또는 201, 실제: " + response.status
  );
  client.assert(response.body.data, "응답 data가 없습니다.");
  client.assert(response.body.data.email, "관리자 이메일이 없습니다.");
});

client.global.set("adminEmail", response.body.data.email);
%}


### 1-2. 관리자 로그인
# @name signInAdmin
POST {{baseUrl}}/api/v1/auth/sign-in
Content-Type: {{contentType}}

{
  "email": "{{adminEmail}}",
  "password": "{{password}}"
}

> {%
client.test("관리자 로그인 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(response.body.data, "응답 data가 없습니다.");
  client.assert(response.body.data.accessToken, "관리자 액세스 토큰이 없습니다.");
});

client.global.set("adminAccessToken", response.body.data.accessToken);
%}


