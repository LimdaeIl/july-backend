### 5. 주문 취소 - 두 번째 주문을 CANCELLED 상태로 변경
# @name cancelOrder2
PATCH {{baseUrl}}/api/v1/orders/{{orderId2}}/cancel
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("주문 취소 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(response.body.data, "응답 data가 없습니다.");
});
%}


### 6-1. 내 주문 목록 조회 - 기본값
# @name getMyOrdersDefault
GET {{baseUrl}}/api/v1/orders
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("기본 주문 목록 조회 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(Array.isArray(response.body.content), "content는 배열이어야 합니다.");
  client.assert(response.body.content.length === 4, "생성한 주문 4건이 조회되어야 합니다.");
  client.assert(response.body.size === 4, "size는 실제 content 개수여야 합니다.");
  client.assert(response.body.hasNext === false, "기본 size=20이므로 다음 페이지가 없어야 합니다.");
  client.assert(response.body.nextCursor === null, "마지막 페이지의 nextCursor는 null이어야 합니다.");
});

client.test("주문 목록 최신 ID 내림차순 검증", function () {
  const content = response.body.content;

  for (let index = 0; index < content.length - 1; index++) {
    client.assert(
        content[index].orderId > content[index + 1].orderId,
        "주문은 orderId 내림차순이어야 합니다."
    );
  }
});

client.test("주문 요약 응답 필드 검증", function () {
  const firstOrder = response.body.content[0];

  client.assert(firstOrder.orderId, "orderId가 없습니다.");
  client.assert(firstOrder.orderNumber, "orderNumber가 없습니다.");
  client.assert(firstOrder.status, "status가 없습니다.");
  client.assert(firstOrder.totalAmount !== null, "totalAmount가 없습니다.");
  client.assert(firstOrder.orderedAt, "orderedAt이 없습니다.");
  client.assert(firstOrder.itemCount === 1, "현재 주문은 상품 1종이어야 합니다.");
  client.assert(firstOrder.representativeItem, "representativeItem이 없습니다.");
  client.assert(firstOrder.representativeItem.productId, "대표 상품 ID가 없습니다.");
  client.assert(firstOrder.representativeItem.productName, "대표 상품명이 없습니다.");
  client.assert(firstOrder.representativeItem.orderPrice !== null, "주문 가격이 없습니다.");
  client.assert(firstOrder.representativeItem.quantity > 0, "주문 수량은 양수여야 합니다.");
  client.assert(firstOrder.representativeItem.lineAmount !== null, "상품별 금액이 없습니다.");
});

client.global.set(
    "orderNumberKeyword",
    response.body.content[0].orderNumber
);
%}


### 6-2. 내 주문 목록 조회 - 첫 페이지(size=2)
# @name getMyOrdersFirstPage
GET {{baseUrl}}/api/v1/orders?size=2
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("주문 목록 첫 페이지 조회 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(Array.isArray(response.body.content), "content는 배열이어야 합니다.");
  client.assert(response.body.content.length === 2, "첫 페이지에는 2건이 있어야 합니다.");
  client.assert(response.body.size === 2, "size는 2여야 합니다.");
  client.assert(response.body.hasNext === true, "다음 페이지가 있어야 합니다.");
  client.assert(response.body.nextCursor !== null, "nextCursor가 있어야 합니다.");
});

client.test("첫 페이지 nextCursor 검증", function () {
  const content = response.body.content;
  const lastOrderId = content[content.length - 1].orderId;

  client.assert(
      response.body.nextCursor === lastOrderId,
      "nextCursor는 현재 페이지 마지막 orderId여야 합니다."
  );
});

client.global.set("ordersNextCursor", response.body.nextCursor);
client.global.set("firstPageFirstOrderId", response.body.content[0].orderId);
client.global.set("firstPageLastOrderId", response.body.content[1].orderId);
%}


### 6-3. 내 주문 목록 조회 - 다음 페이지
# @name getMyOrdersNextPage
GET {{baseUrl}}/api/v1/orders?cursor={{ordersNextCursor}}&size=2
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("주문 목록 다음 페이지 조회 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(Array.isArray(response.body.content), "content는 배열이어야 합니다.");
  client.assert(response.body.content.length === 2, "다음 페이지에는 2건이 있어야 합니다.");
  client.assert(response.body.size === 2, "size는 2여야 합니다.");
  client.assert(response.body.hasNext === false, "마지막 페이지여야 합니다.");
  client.assert(response.body.nextCursor === null, "마지막 페이지의 nextCursor는 null이어야 합니다.");
});

client.test("페이지 간 주문 중복 및 커서 경계 검증", function () {
  const content = response.body.content;

  content.forEach(function (order) {
    client.assert(
        order.orderId < Number(client.global.get("ordersNextCursor")),
        "다음 페이지 주문 ID는 cursor보다 작아야 합니다."
    );

    client.assert(
        order.orderId !== Number(client.global.get("firstPageFirstOrderId"))
        && order.orderId !== Number(client.global.get("firstPageLastOrderId")),
        "첫 페이지 주문과 중복되면 안 됩니다."
    );
  });
});
%}


### 6-4. 상태 필터 - PENDING_PAYMENT
# @name getMyPendingOrders
GET {{baseUrl}}/api/v1/orders?status=PENDING_PAYMENT&size=20
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("결제 대기 주문 필터 조회 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(response.body.content.length === 3, "PENDING_PAYMENT 주문은 3건이어야 합니다.");

  response.body.content.forEach(function (order) {
    client.assert(
        order.status === "PENDING_PAYMENT",
        "모든 주문 상태는 PENDING_PAYMENT여야 합니다."
    );
  });
});
%}


### 6-5. 상태 필터 - CANCELLED
# @name getMyCancelledOrders
GET {{baseUrl}}/api/v1/orders?status=CANCELLED&size=20
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("취소 주문 필터 조회 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(response.body.content.length === 1, "CANCELLED 주문은 1건이어야 합니다.");
  client.assert(
      response.body.content[0].status === "CANCELLED",
      "조회된 주문 상태는 CANCELLED여야 합니다."
  );
  client.assert(
      response.body.content[0].orderId === Number(client.global.get("orderId2")),
      "취소한 두 번째 주문이 조회되어야 합니다."
  );
});
%}


### 6-6. 상품명 키워드 필터 - 키보드
# @name getMyOrdersByProductKeyword
GET {{baseUrl}}/api/v1/orders?keyword=%ED%82%A4%EB%B3%B4%EB%93%9C&size=20
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("상품명 키워드 검색 성공", function () {
  client.assert(response.status === 200, "예상 상태 코드: 200");
  client.assert(response.body.content.length === 2, "키보드 주문은 2건이어야 합니다.");

  response.body.content.forEach(function (order) {
    client.assert(
        order.representativeItem.productName.includes("키보드"),
        "대표 상품명에 '키보드'가 포함되어야 합니다."
    );
  });
});
%}


