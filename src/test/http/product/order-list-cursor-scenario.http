### 7-6. 실패 - 잘못된 주문 상태
# @name getMyOrdersInvalidStatus
GET {{baseUrl}}/api/v1/orders?status=INVALID&size=20
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("잘못된 주문 상태 변환 실패", function () {
  client.assert(response.status === 400, "예상 상태 코드: 400");
});
%}


### 7-7. 실패 - 검색어 100자 초과
# @name getMyOrdersKeywordTooLong
GET {{baseUrl}}/api/v1/orders?keyword=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa&size=20
Authorization: Bearer {{buyerAccessToken}}

> {%
client.test("검색어 길이 검증 실패", function () {
  client.assert(response.status === 400, "예상 상태 코드: 400");
});
%}
