### 28. 다중 상품 주문 생성
# @name createOrder
POST {{baseUrl}}/api/v1/orders
Content-Type: {{contentType}}
Authorization: Bearer {{memberAccessToken}}

{
  "items": [
    {
      "productId": {{productId1}},
      "quantity": 2
    },
    {
      "productId": {{productId2}},
      "quantity": 1
    }
  ]
}

> {%
const orderId = response.body.data.orderId ?? response.body.data.id;
client.global.set("orderId", orderId);
%}

### 29. 주문 상세 조회
# @name getOrder
GET {{baseUrl}}/api/v1/orders/{{orderId}}
Authorization: Bearer {{memberAccessToken}}


