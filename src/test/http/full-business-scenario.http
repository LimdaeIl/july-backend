Authorization: Bearer {{adminAccessToken}}

> {%
client.test("상품 2 삭제 성공", function () {
    client.assert(
        response.status === 200 || response.status === 204,
        "상품 삭제 응답은 200 또는 204여야 합니다."
    );
});
%}

