@baseUrl = http://localhost:8080
@contentType = application/json
@adminEmail = admin@example.com
@adminPassword = Password123!
@memberPassword = Password123!


### 회원가입
# @name signUp
POST http://localhost:8080/api/v1/auth/sign-up
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "Password123!",
  "name": "테스트회원",
  "phone": "01012345678",
  "address": {
    "city": "서울특별시",
    "state": "강남구",
    "zip": "06236",
    "country": "대한민국"
  }
}

### 1. 관리자 로그인
# @name adminSignIn
POST {{baseUrl}}/api/v1/auth/sign-in
Content-Type: {{contentType}}

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
client.global.set("adminAccessToken", response.body.data.accessToken);
%}

### 2. 회원 가입
# @name memberSignUp
POST {{baseUrl}}/api/v1/auth/sign-up
Content-Type: {{contentType}}

{
  "email": "july-member-{{$timestamp}}@example.com",
  "password": "{{memberPassword}}",
  "name": "통합테스트회원",
  "phone": "010{{$random.integer(10000000, 99999999)}}",
  "address": {
    "city": "서울특별시",
    "state": "강남구",
    "zip": "06236",
    "country": "대한민국"
  }
}

> {%
client.global.set("memberEmail", response.body.data.email);
%}

### 3. 회원 로그인
# @name memberSignIn
POST {{baseUrl}}/api/v1/auth/sign-in
Content-Type: {{contentType}}

{
  "email": "{{memberEmail}}",
  "password": "{{memberPassword}}"
}

> {%
client.global.set("memberAccessToken", response.body.data.accessToken);
%}

### 4. 내 정보 조회
# @name getMe
GET {{baseUrl}}/api/v1/members
Authorization: Bearer {{memberAccessToken}}

> {%
%}

### 5. 상품 1 생성
# @name createProduct1
POST {{baseUrl}}/api/v1/admin/products
Content-Type: {{contentType}}
Authorization: Bearer {{adminAccessToken}}

{
  "name": "통합테스트 기계식 키보드 {{$timestamp}}",
  "price": 129000,
  "initialQuantity": 100
}

> {%
const productId = response.body.data.productId ?? response.body.data.id;
client.assert(productId != null, "상품 1 ID가 필요합니다.");
client.global.set("productId1", productId);
%}

### 6. 상품 2 생성
# @name createProduct2
POST {{baseUrl}}/api/v1/admin/products
Content-Type: {{contentType}}
Authorization: Bearer {{adminAccessToken}}

{
  "name": "통합테스트 게이밍 마우스 {{$timestamp}}",
  "price": 59000,
  "initialQuantity": 100
}

> {%
const productId = response.body.data.productId ?? response.body.data.id;
client.assert(productId != null, "상품 2 ID가 필요합니다.");
client.global.set("productId2", productId);
%}

### 7. 상품 3 생성
# @name createProduct3
POST {{baseUrl}}/api/v1/admin/products
Content-Type: {{contentType}}
Authorization: Bearer {{adminAccessToken}}

{
  "name": "통합테스트 USB 허브 {{$timestamp}}",
  "price": 29000,
  "initialQuantity": 100
}

> {%
const productId = response.body.data.productId ?? response.body.data.id;
client.assert(productId != null, "상품 3 ID가 필요합니다.");
client.global.set("productId3", productId);
%}

### 8. 상품 1 정보 수정
# @name updateProduct1
PATCH {{baseUrl}}/api/v1/admin/products/{{productId1}}
Content-Type: {{contentType}}
Authorization: Bearer {{adminAccessToken}}

{
  "name": "통합테스트 기계식 키보드 수정",
  "price": 125000
}

