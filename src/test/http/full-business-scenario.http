### 19. 장바구니 최초 조회
# @name getEmptyCart
GET {{baseUrl}}/api/v1/cart
Authorization: Bearer {{memberAccessToken}}

### 20. 상품 1 장바구니 추가
# @name addCartItem1
POST {{baseUrl}}/api/v1/cart/items
Content-Type: {{contentType}}
Authorization: Bearer {{memberAccessToken}}

{
  "productId": {{productId1}},
  "quantity": 2
}

> {%
const cartItemId = response.body.data.cartItemId ?? response.body.data.id;
client.assert(cartItemId != null, "장바구니 상품 1 ID가 필요합니다.");
client.global.set("cartItemId1", cartItemId);
%}

